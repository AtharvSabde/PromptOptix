# PromptOptimizer Pro - Environment Variables Template
# Copy this file to .env and fill in your actual values
# At least one LLM provider API key is required

# =============================================================================
# LLM PROVIDER API KEYS
# =============================================================================

# Gemini API Key (default provider)
# Get your key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anthropic Claude API Key
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Groq API Key
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI API Key
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=


# =============================================================================
# LLM PROVIDER SELECTION
# =============================================================================

# Primary provider for optimization: anthropic | groq | openai | gemini
DEFAULT_PROVIDER=gemini

# Provider and model used as evaluation judge (can differ from DEFAULT_PROVIDER)
JUDGE_PROVIDER=gemini
JUDGE_MODEL=gemini-2.5-pro


# =============================================================================
# MODEL SELECTION (per provider)
# =============================================================================

ANTHROPIC_MODEL=claude-sonnet-4-6
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.5-pro


# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Secret key for sessions — change this to a random string in production
SECRET_KEY=change-me-to-a-random-string

# Backend server host and port
HOST=0.0.0.0
PORT=8000

# App environment: development | production | testing
APP_ENV=development

# Debug mode: True for development, False for production
APP_DEBUG=True

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174


# =============================================================================
# MULTI-AGENT CONFIGURATION
# =============================================================================

# Number of parallel agents (1–10)
NUM_AGENTS=4

# Consensus threshold for defect agreement (0.0–1.0)
CONSENSUS_THRESHOLD=0.7


# =============================================================================
# TOKEN & TIMEOUT LIMITS
# =============================================================================

MAX_ANALYSIS_TOKENS=4000
MAX_OPTIMIZATION_TOKENS=8000
MAX_PROMPT_LENGTH=50000

# Timeout per LLM call in seconds (increase for slow providers)
LLM_CALL_TIMEOUT=120


# =============================================================================
# ADVANCED OPTIMIZATION STRATEGIES
# =============================================================================

# DGEO: Defect-Guided Evolutionary Optimization
DGEO_POPULATION_SIZE=5
DGEO_GENERATIONS=3

# SHDT: Scored History with Defect Trajectories
SHDT_MAX_ITERATIONS=4
SHDT_TARGET_SCORE=8.0
SHDT_MIN_IMPROVEMENT=0.3

# CDRAF: Critic-Driven Refinement with Agent Feedback
CDRAF_MAX_ROUNDS=2


# =============================================================================
# EVALUATION SETTINGS
# =============================================================================

# Enable BERTScore semantic similarity (requires sentence-transformers)
ENABLE_BERTSCORE=false

# Enable statistical significance testing
ENABLE_SIGNIFICANCE_TESTING=true

TEST_ITERATIONS=5
TEST_TIMEOUT=30


# =============================================================================
# LOGGING
# =============================================================================

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log format: json | text
LOG_FORMAT=text
