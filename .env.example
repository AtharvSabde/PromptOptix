# PromptOptimizer Pro - Environment Variables Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# API KEYS (Required)
# =============================================================================

# Anthropic Claude API Key
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Groq API Key (Optional - for fallback/comparison)
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here


# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Backend server port (default: 8000)
PORT=8000

# Backend server host (default: 0.0.0.0 for all interfaces)
HOST=0.0.0.0

# Flask environment: development, production, testing
FLASK_ENV=development

# Flask debug mode: True for development, False for production
FLASK_DEBUG=True


# =============================================================================
# CORS CONFIGURATION
# =============================================================================

# Allowed CORS origins (comma-separated, no spaces)
# Default frontend ports: 5173 (Vite default), 5174 (Vite fallback)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174


# =============================================================================
# LLM MODEL CONFIGURATION
# =============================================================================

# Primary LLM Provider: anthropic or groq
PRIMARY_LLM_PROVIDER=anthropic

# Anthropic Model Selection
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Groq Model Selection
GROQ_MODEL=llama-3.3-70b-versatile

# Temperature (0.0 - 1.0)
DEFAULT_TEMPERATURE=0.3

# Max tokens
MAX_TOKENS=4096


# =============================================================================
# MULTI-AGENT CONFIGURATION
# =============================================================================

# Number of agents (3 or 4)
AGENT_COUNT=4

# Parallel execution
ENABLE_PARALLEL_AGENTS=True

# Consensus threshold (0.0 - 1.0)
CONSENSUS_THRESHOLD=0.6


# =============================================================================
# LOGGING
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json or text
LOG_FORMAT=text
