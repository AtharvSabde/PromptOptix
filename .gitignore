.yarn-integrity
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# ===== Project Specific =====
# Temporary files
temp/
tmp/
*.tmp
*.temp

# Data files (may contain sensitive information)
data/benchmark_results/*.json
data/benchmark_results/*.csv
data/test_results/

# API response cache
cache/
*.cache

# Database files
*.db
*.sqlite
*.sqlite3

# Generated files
generated/
output/

# User uploaded prompts (may contain sensitive data)
user_prompts/
submissions/

# Model files (if storing embeddings)
models/
*.pkl
*.pickle
*.h5
*.pt
*.pth
*.onnx

# Evaluation results with potentially sensitive data
evaluation_results/
experiment_logs/

# Cost tracking files (may contain API usage data)
cost_logs/
usage_stats/

# Backup files
*.bak
*.backup
*~.nib

# ===== Docker =====
# Docker files to ignore
docker-compose.override.yml
.dockerignore

# ===== Security =====
# Private keys
*.pem
*.key
*.crt
*.cert
secrets/
credentials/

# API keys and tokens
.api_keys
tokens.json

# ===== Miscellaneous =====
# Archive files
*.zip
*.tar.gz
*.rar

# Large files
*.large

# System files
.fuse_hidden*

# Temporary office files
~$*.doc*
~$*.xls*
~$*.ppt*

# ===== Keep Empty Directories =====
# These files ensure empty directories are tracked
!.gitkeep
!**/.gitkeep

# ===== Frontend (Future) =====
# Build outputs
frontend/build/
frontend/dist/

# ===== Documentation Build =====
docs/build/
docs/_build/